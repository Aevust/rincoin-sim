# rincoin-sim: enforce LF for all text files
* text=auto eol=lf

# C / C++ source
*.c   text eol=lf
*.cc  text eol=lf
*.cpp text eol=lf
*.h   text eol=lf
*.hpp text eol=lf

# Build system
configure  text eol=lf
*.ac       text eol=lf
*.am       text eol=lf
*.mk       text eol=lf
*.in       text eol=lf

# Scripts
*.sh  text eol=lf

# Python (functional test suite)
*.py  text eol=lf

# Documentation / config
*.md    text eol=lf
*.txt   text eol=lf
*.rst   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.xml   text eol=lf
COPYING text eol=lf

# Binary – must not be line-end converted
*.png   binary
*.ico   binary
*.gif   binary
*.jpg   binary
*.jpeg  binary
*.bmp   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# git archive version substitution (Bitcoin → Litecoin → Rincoin upstream)
src/clientversion.cpp export-subst
